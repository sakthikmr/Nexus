{
  "entities": {
    "Vendor": {
      "title": "Vendor",
      "description": "A partner organization providing services or staff.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Onboarding", "Suspended"] },
        "category": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "Resource": {
      "title": "Resource",
      "description": "A candidate or employee managed through the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "vendorId": { "type": "string" },
        "billingRate": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "vendorId"]
    },
    "Ticket": {
      "title": "Support Ticket",
      "description": "A support request or inquiry raised by a vendor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "category": { "type": "string" },
        "subject": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "assignedTo": { "type": "string" },
        "slaBreached": { "type": "boolean" },
        "isEscalated": { "type": "boolean" }
      },
      "required": ["id", "vendorId", "subject", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A commercial invoice from a vendor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "dueDate": { "type": "string" }
      },
      "required": ["id", "invoiceNumber", "vendorId", "amount", "status"]
    },
    "Procurement": {
      "title": "Procurement Requirement",
      "description": "A sourcing request for goods or services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "budget": { "type": "string" }
      },
      "required": ["id", "title", "type", "status"]
    }
  },
  "firestore": {
    "vendors": {
      "schema": "Vendor",
      "description": "Global vendor directory."
    },
    "resources": {
      "schema": "Resource",
      "description": "Deployed and benched resources."
    },
    "tickets": {
      "schema": "Ticket",
      "description": "Vendor support queue."
    },
    "invoices": {
      "schema": "Invoice",
      "description": "Commercial billing records."
    },
    "procurement": {
      "schema": "Procurement",
      "description": "Sourcing requirements."
    }
  }
}

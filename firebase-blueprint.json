
{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user representing internal staff or vendor personnel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "roleId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "roleId", "status"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "Primary vendor organization profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Onboarding", "Pending Review", "Suspended", "Blacklisted"] },
        "category": { "type": "string" },
        "risk": { "type": "string", "enum": ["Low", "Med", "High", "N/A"] },
        "score": { "type": "number" },
        "location": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "Candidate": {
      "title": "Candidate",
      "description": "Individual talent profile in the recruitment pipeline",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "positionId": { "type": "string" },
        "stage": { "type": "string" },
        "status": { "type": "string" },
        "vendorId": { "type": "string" },
        "experience": { "type": "string" }
      },
      "required": ["id", "name", "positionId", "stage"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Commercial billing document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vendorId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Submitted", "Under Review", "Approved", "Paid", "Disputed", "Overdue"] },
        "dueDate": { "type": "string", "format": "date" }
      },
      "required": ["id", "vendorId", "amount", "status", "dueDate"]
    },
    "Requirement": {
      "title": "Requirement",
      "description": "Procurement requirement or SOW request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "budget": { "type": "string" },
        "deadline": { "type": "string", "format": "date" }
      },
      "required": ["id", "title", "status", "deadline"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles"
    },
    "/vendors/{vendorId}": {
      "schema": "Vendor",
      "description": "Vendor organization profiles"
    },
    "/vendors/{vendorId}/docs/{docId}": {
      "schema": "object",
      "description": "Compliance documents for a vendor"
    },
    "/candidates/{canId}": {
      "schema": "Candidate",
      "description": "Talent database"
    },
    "/candidates/{canId}/history/{histId}": {
      "schema": "object",
      "description": "Audit trail of candidate stage movements"
    },
    "/invoices/{invId}": {
      "schema": "Invoice",
      "description": "Financial billing records"
    },
    "/procurement/{reqId}": {
      "schema": "Requirement",
      "description": "Procurement requirements and RFQs"
    },
    "/procurement/{reqId}/bids/{bidId}": {
      "schema": "object",
      "description": "Vendor bids for a requirement"
    },
    "/tickets/{tickId}": {
      "schema": "object",
      "description": "Support tickets"
    },
    "/tickets/{tickId}/comments/{commId}": {
      "schema": "object",
      "description": "Conversation thread on a ticket"
    },
    "/audit_logs/{auditId}": {
      "schema": "object",
      "description": "Immutable system audit trail"
    }
  }
}
